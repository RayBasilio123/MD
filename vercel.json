{
  "buildCommand": "cd minedebug/ui_kits/operations && npm install && npm run build",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/dashboard",
      "destination": "/minedebug/ui_kits/operations/dist/index.html"
    },
    {
      "source": "/dashboard/(.*)",
      "destination": "/minedebug/ui_kits/operations/dist/$1"
    }
  ]
}